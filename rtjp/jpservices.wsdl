            <xsd:simpleType name="OJPString" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                <xsd:restriction base="xsd:string" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                    <xsd:whiteSpace value="collapse" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:minLength value="1" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:maxLength value="255" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                </xsd:restriction>
            </xsd:simpleType>
            <xsd:complexType name="CrsCode" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                <xsd:choice xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                    <xsd:annotation xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                        <xsd:documentation xmlns:xsd="http://www.w3.org/2001/XMLSchema">CRS code of a station or station
                            group
                        </xsd:documentation>
                    </xsd:annotation>
                    <xsd:element name="stationCRS" type="StationCrs" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:element name="groupCRS" type="GroupCrs" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                </xsd:choice>
            </xsd:complexType>
            <xsd:complexType name="CrsNlcCode" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                <xsd:choice xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                    <xsd:annotation xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                        <xsd:documentation xmlns:xsd="http://www.w3.org/2001/XMLSchema">CRS code or NLC code of a
                            station or station
                            group
                        </xsd:documentation>
                    </xsd:annotation>
                    <xsd:element name="stationCRS" type="StationCrs" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:element name="groupCRS" type="GroupCrs" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:element name="nlcCode" type="NLC" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                </xsd:choice>
            </xsd:complexType>
            <xsd:simpleType name="StationCrs" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                <xsd:restriction base="xsd:string" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                    <xsd:pattern value="[A-Z0-9]{3}" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                </xsd:restriction>
            </xsd:simpleType>
            <xsd:complexType name="StationTime" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                <xsd:sequence xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                    <xsd:element minOccurs="0" name="stationCRS" type="StationCrs"
                                 xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:element minOccurs="0" name="realTime" type="xsd:dateTime"
                                 xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:element minOccurs="0" name="scheduledTime" type="xsd:dateTime"
                                 xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                </xsd:sequence>
            </xsd:complexType>
            <xsd:simpleType name="GroupCrs" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                <xsd:restriction base="xsd:string" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                    <xsd:pattern value="[0-9]{1,3}" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                </xsd:restriction>
            </xsd:simpleType>
            <xsd:complexType name="Location" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                <xsd:choice xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                    <xsd:annotation xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                        <xsd:documentation xmlns:xsd="http://www.w3.org/2001/XMLSchema">Postcode or a CrsCode
                        </xsd:documentation>
                    </xsd:annotation>
                    <xsd:element name="postcodeDetails" type="PostcodeDetails"
                                 xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:element name="station" type="CrsCode" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                </xsd:choice>
            </xsd:complexType>
            <xsd:complexType name="PostcodeDetails" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                <xsd:sequence xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                    <xsd:element name="postcode" type="PostcodeType" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:element maxOccurs="3" minOccurs="0" name="stations" type="StationCrs"
                                 xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                </xsd:sequence>
            </xsd:complexType>
            <xsd:simpleType name="PostcodeType" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                <xsd:restriction base="xsd:string" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                    <xsd:pattern
                            value="[A-PR-UWYZ0-9][A-HK-Y0-9][AEHMNPRTVXY0-9]?[ABEHMNPRVWXY0-9]? {0,1}[0-9][ABD-HJLN-UW-Z]{2}|GIR 0AA"
                            xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                </xsd:restriction>
            </xsd:simpleType>
            <xsd:simpleType name="RailCardCode" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                <xsd:restriction base="xsd:string" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                    <xsd:minLength value="3" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:maxLength value="3" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                </xsd:restriction>
            </xsd:simpleType>
            <xsd:simpleType name="FareClassEnum" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                <xsd:restriction base="xsd:NMTOKEN" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                    <xsd:enumeration value="ANY" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:enumeration value="STANDARD" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:enumeration value="FIRST" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                </xsd:restriction>
            </xsd:simpleType>
            <xsd:simpleType name="FareCategoryEnum" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                <xsd:restriction base="xsd:NMTOKEN" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                    <xsd:enumeration value="ADVANCE" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:enumeration value="OFF-PEAK" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:enumeration value="ANYTIME" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                </xsd:restriction>
            </xsd:simpleType>
            <xsd:simpleType name="IntermediateEnumType" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                <xsd:annotation xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                    <xsd:documentation xmlns:xsd="http://www.w3.org/2001/XMLSchema">The type of intermediate the user
                        wants.
                    </xsd:documentation>
                </xsd:annotation>
                <xsd:restriction base="xsd:NMTOKEN" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                    <xsd:enumeration value="Via" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:enumeration value="Avoid" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:enumeration value="Interchange" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:enumeration value="ExcludeInterchange" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                </xsd:restriction>
            </xsd:simpleType>
            <xsd:simpleType name="MaxChanges" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                <xsd:restriction base="xsd:NMTOKEN" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                    <xsd:enumeration value="0" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:enumeration value="1" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:enumeration value="2" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:enumeration value="3" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:enumeration value="ANY" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                </xsd:restriction>
            </xsd:simpleType>
            <xsd:simpleType name="IncreaseInterchangeTime" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                <xsd:annotation xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                    <xsd:documentation xmlns:xsd="http://www.w3.org/2001/XMLSchema">The number of minutes the user wants
                        to increase
                        the interchange time.
                    </xsd:documentation>
                </xsd:annotation>
                <xsd:restriction base="xsd:NMTOKEN" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                    <xsd:enumeration value="0" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:enumeration value="30" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:enumeration value="60" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:enumeration value="90" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:enumeration value="120" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                </xsd:restriction>
            </xsd:simpleType>
            <xsd:complexType name="PassengerCounts" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                <xsd:sequence xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                    <xsd:element name="adult" type="PassengerCount" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:element name="child" type="PassengerCount" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                </xsd:sequence>
            </xsd:complexType>
            <xsd:simpleType name="PassengerCount" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                <xsd:restriction base="xsd:int" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                    <xsd:minInclusive value="0" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:maxInclusive value="8" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                </xsd:restriction>
            </xsd:simpleType>
            <xsd:complexType name="Station" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                <xsd:sequence xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                    <xsd:element name="name" type="StationOrGroupName" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:element name="crs" type="StationCrs" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:element minOccurs="0" name="nlc" type="NLC" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:element minOccurs="0" name="tiploc" type="Tiploc"
                                 xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:element minOccurs="0" name="probability" type="ProbabilityWeighting"
                                 xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                </xsd:sequence>
            </xsd:complexType>
            <xsd:complexType name="StationGroup" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                <xsd:sequence xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                    <xsd:element name="name" type="StationOrGroupName" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:element name="crs" type="GroupCrs" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:element maxOccurs="unbounded" name="station" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                        <xsd:complexType xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                            <xsd:sequence xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                                <xsd:element name="name" type="StationOrGroupName"
                                             xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                                <xsd:element name="crs" type="StationCrs" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                                <xsd:element minOccurs="0" name="nlc" type="NLC"
                                             xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                                <xsd:element minOccurs="0" name="tiploc" type="Tiploc"
                                             xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                            </xsd:sequence>
                        </xsd:complexType>
                    </xsd:element>
                    <xsd:element name="probability" type="ProbabilityWeighting"
                                 xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                </xsd:sequence>
            </xsd:complexType>
            <xsd:simpleType name="TravelModeEnum" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                <xsd:restriction base="xsd:NMTOKEN" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                    <xsd:enumeration value="SCHEDULED_BUS" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:enumeration value="REPLACEMENT_BUS" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:enumeration value="TRAIN" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:enumeration value="FERRY" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:enumeration value="WALK" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:enumeration value="UNDERGROUND" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:enumeration value="TAXI" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:enumeration value="METRO" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:enumeration value="TRAMLINK" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:enumeration value="PLATFORM_CHANGE" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:enumeration value="CHECK_IN_TIME" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:enumeration value="HOVERCRAFT" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:enumeration value="TRANSFER" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:enumeration value="TRAM" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:enumeration value="DLR" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:enumeration value="LU" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:enumeration value="DLR_LU" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:enumeration value="WALK_TUBE" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:enumeration value="WALK_DLR" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:enumeration value="WALK_TUBE_DLR" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                </xsd:restriction>
            </xsd:simpleType>
            <xsd:simpleType name="AdultOrChildEnum" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                <xsd:restriction base="xsd:NMTOKEN" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                    <xsd:enumeration value="ADULT" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:enumeration value="CHILD" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                </xsd:restriction>
            </xsd:simpleType>
            <xsd:simpleType name="FareDirectionEnum" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                <xsd:restriction base="xsd:NMTOKEN" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                    <xsd:enumeration value="OUTWARD" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:enumeration value="INWARD" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:enumeration value="RETURN" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:enumeration value="OTHER" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                </xsd:restriction>
            </xsd:simpleType>
            <xsd:simpleType name="FareSearchStrategyEnum" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                <xsd:restriction base="xsd:NMTOKEN" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                    <xsd:enumeration value="FASTEST" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:enumeration value="CHEAPEST" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                </xsd:restriction>
            </xsd:simpleType>
            <xsd:simpleType name="StationOrGroupName" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                <xsd:restriction base="xsd:string" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                    <xsd:minLength value="0" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:maxLength value="255" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                </xsd:restriction>
            </xsd:simpleType>
            <xsd:simpleType name="FareDescription" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                <xsd:restriction base="xsd:string" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                    <xsd:minLength value="0" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:maxLength value="255" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                </xsd:restriction>
            </xsd:simpleType>
            <xsd:complexType name="Fare" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                <xsd:sequence xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                    <xsd:element name="id" type="Id" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:element name="description" type="FareDescription"
                                 xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:element name="totalPrice" type="PriceInPence" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:element name="undiscountedPrices" type="Prices" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:element name="typeCode" type="FareCode" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:element name="fareClass" type="FareClassEnum" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:element name="fareCategory" type="FareCategoryEnum"
                                 xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:element name="routeCode" type="RouteCode" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:element minOccurs="0" name="fareSetter" type="FareSetter"
                                 xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:element name="startLegId" type="Id" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:element name="endLegId" type="Id" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:element minOccurs="0" name="originNlc" type="NLC"
                                 xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:element minOccurs="0" name="destinationNlc" type="NLC"
                                 xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:element minOccurs="0" name="fareType" type="FareType"
                                 xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:element name="direction" type="FareDirectionEnum"
                                 xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:element minOccurs="0" name="canCrossLondon" type="xsd:boolean"
                                 xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:element minOccurs="0" name="adultStatusCode" type="PassengerStatusCodeType"
                                 xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:element minOccurs="0" name="childStatusCode" type="PassengerStatusCodeType"
                                 xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:element minOccurs="0" name="ticketRestriction" type="TicketRestrictionType"
                                 xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:element minOccurs="0" name="utsZones" type="xsd:nonNegativeInteger"
                                 xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:element minOccurs="0" name="individualFare" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                        <xsd:complexType xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                            <xsd:sequence xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                                <xsd:element name="prices" type="Prices" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                                <xsd:element name="accompaniedPrices" type="Prices"
                                             xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                                <xsd:element name="passengers" type="PassengerCounts"
                                             xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                                <xsd:element name="accompaniedPassengers" type="PassengerCounts"
                                             xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                            </xsd:sequence>
                        </xsd:complexType>
                    </xsd:element>
                    <xsd:sequence xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                        <xsd:element maxOccurs="unbounded" minOccurs="0" name="railcardFare"
                                     xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                            <xsd:complexType xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                                <xsd:sequence xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                                    <xsd:element name="code" type="RailCardCode"
                                                 xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                                    <xsd:element name="count" type="xsd:int"
                                                 xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                                    <xsd:element name="prices" type="Prices"
                                                 xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                                    <xsd:element name="passengers" type="PassengerCounts"
                                                 xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                                    <xsd:element minOccurs="0" name="adultStatusCode" type="PassengerStatusCodeType"
                                                 xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                                    <xsd:element minOccurs="0" name="childStatusCode" type="PassengerStatusCodeType"
                                                 xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                                </xsd:sequence>
                            </xsd:complexType>
                        </xsd:element>
                    </xsd:sequence>
                    <xsd:element minOccurs="0" name="groupFare" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                        <xsd:complexType xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                            <xsd:sequence xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                                <xsd:element name="price" type="PriceInPence"
                                             xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                                <xsd:element name="noOfTickets" type="xsd:int"
                                             xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                            </xsd:sequence>
                        </xsd:complexType>
                    </xsd:element>
                    <xsd:element maxOccurs="unbounded" minOccurs="0" name="invalidFareComponent" type="Fare"
                                 xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                </xsd:sequence>
            </xsd:complexType>
            <xsd:simpleType name="PassengerStatusCodeType" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                <xsd:restriction base="xsd:string" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                    <xsd:minLength value="3" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:maxLength value="3" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                </xsd:restriction>
            </xsd:simpleType>
            <xsd:simpleType name="Tiploc" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                <xsd:restriction base="xsd:string" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                    <xsd:minLength value="0" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:maxLength value="7" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                </xsd:restriction>
            </xsd:simpleType>
            <xsd:simpleType name="NLC" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                <xsd:restriction base="xsd:string" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                    <xsd:minLength value="0" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:maxLength value="4" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                </xsd:restriction>
            </xsd:simpleType>
            <xsd:simpleType name="FareType" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                <xsd:restriction base="xsd:NMTOKEN" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                    <xsd:enumeration value="SMARTCARDS" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:enumeration value="OPAYG" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:enumeration value="TRAVELCARDS" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                </xsd:restriction>
            </xsd:simpleType>
            <xsd:simpleType name="ProbabilityWeighting" xmlns:xsd="http://www.w3.org/2001/XMLSchema">

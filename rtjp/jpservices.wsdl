<?xml version="1.0" encoding="UTF-8"?>
<wsdl:definitions xmlns:wsdl="http://schemas.xmlsoap.org/wsdl/" xmlns:sch0="http://www.thalesgroup.com/ojp/jpservices"
                  xmlns:sch1="http://www.thalesgroup.com/ojp/common" xmlns:soap="http://schemas.xmlsoap.org/wsdl/soap/"
                  xmlns:tns="http://ojp.nationalrail.co.uk" targetNamespace="http://ojp.nationalrail.co.uk">
    <wsdl:types>
        <xsd:schema xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns="http://www.thalesgroup.com/ojp/jpservices"
                    xmlns:ns0="http://www.thalesgroup.com/ojp/common" attributeFormDefault="unqualified"
                    elementFormDefault="qualified" targetNamespace="http://www.thalesgroup.com/ojp/jpservices">
            <xsd:import namespace="http://www.thalesgroup.com/ojp/common" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
            <xsd:import namespace="http://www.thalesgroup.com/ojp/common" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
            <xsd:import namespace="http://www.thalesgroup.com/ojp/common" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
            <xsd:element name="DepartureBoardRequest" type="DepartureBoardRequestType"
                         xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
            <xsd:element name="DepartureBoardResponse" type="DepartureBoardResponseType"
                         xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
            <xsd:complexType name="DepartureBoardRequestType" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                <xsd:annotation xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                    <xsd:documentation xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                        Retrieve real time departure and arrival information for either a specified station
                        or the User's default Home or Work station. By Default, the journeys departing or arriving from
                        now are
                        retrieved. However, using the 'fromTime' parameter allows journeys in the future to be returned.
                    </xsd:documentation>
                </xsd:annotation>
                <xsd:sequence xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                    <xsd:element name="specifiedStation" type="SpecifiedStationDetail"
                                 xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:element name="stoppingPattern" type="ns0:StoppingPatternType"
                                 xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:element minOccurs="0" name="fromTime" type="xsd:dateTime"
                                 xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                </xsd:sequence>
            </xsd:complexType>
            <xsd:complexType name="DepartureBoardResponseType" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                <xsd:annotation xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                    <xsd:documentation xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                        Departure board information for a specified station. A maximum of 20 journeys are returned.
                        The number of journeys omitted from the response will also be provided.
                    </xsd:documentation>
                </xsd:annotation>
                <xsd:complexContent xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                    <xsd:extension base="ns0:ReturnResponseType" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                        <xsd:sequence xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                            <xsd:element name="servicesOmitted" type="ns0:ServicesOmittedInteger"
                                         xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                            <xsd:element maxOccurs="20" name="stationJourneyDetail" type="ns0:StationJourneyDetail"
                                         xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                        </xsd:sequence>
                    </xsd:extension>
                </xsd:complexContent>
            </xsd:complexType>
            <xsd:complexType name="SpecifiedStationDetail" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                <xsd:annotation xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                    <xsd:documentation xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                        The primary station is the station of interest i.e. journeys departing or
                        arriving from this station will be returned. An optional filter station can also be provided.
                        If given, the response will be contain only journeys which pass through this station.
                    </xsd:documentation>
                </xsd:annotation>
                <xsd:sequence xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                    <xsd:element name="primaryStationCrs" type="ns0:StationCrs"
                                 xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    <xsd:element minOccurs="0" name="filterStationCrs" type="ns0:StationCrs"
                                 xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                </xsd:sequence>
            </xsd:complexType>
            <xsd:element name="RealtimeJourneyPlanRequest" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                <xsd:annotation xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                    <xsd:documentation xmlns:xsd="http://www.w3.org/2001/XMLSchema">Realtime journey planning request
                    </xsd:documentation>
                </xsd:annotation>
                <xsd:complexType xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                    <xsd:sequence xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                        <xsd:element name="origin" type="ns0:CrsCode" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                        <xsd:element name="destination" type="ns0:CrsCode"
                                     xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                        <xsd:element name="realtimeEnquiry" type="ns0:RealtimeEnquiryType"
                                     xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                        <xsd:element name="outwardTime" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                            <xsd:complexType xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                                <xsd:choice xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                                    <xsd:annotation xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                                        <xsd:documentation xmlns:xsd="http://www.w3.org/2001/XMLSchema">Request outward
                                            journeys arriving or departing by a certain time
                                        </xsd:documentation>
                                    </xsd:annotation>
                                    <xsd:element name="arriveBy" type="xsd:dateTime"
                                                 xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                                    <xsd:element name="departBy" type="xsd:dateTime"
                                                 xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                                    <xsd:element name="firstTrainOfDay" type="xsd:date"
                                                 xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                                    <xsd:element name="lastTrainOfDay" type="xsd:date"
                                                 xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                                </xsd:choice>
                            </xsd:complexType>
                        </xsd:element>
                        <xsd:element minOccurs="0" name="inwardTime" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                            <xsd:annotation xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                                <xsd:documentation xmlns:xsd="http://www.w3.org/2001/XMLSchema">Populate the inward time
                                    element to retrieve return journeys.
                                </xsd:documentation>
                            </xsd:annotation>
                            <xsd:complexType xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                                <xsd:choice xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                                    <xsd:annotation xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                                        <xsd:documentation xmlns:xsd="http://www.w3.org/2001/XMLSchema">Request return
                                            inward journeys arriving or departing by a certain time
                                        </xsd:documentation>
                                    </xsd:annotation>
                                    <xsd:element name="arriveBy" type="xsd:dateTime"
                                                 xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                                    <xsd:element name="departBy" type="xsd:dateTime"
                                                 xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                                    <xsd:element name="firstTrainOfDay" type="xsd:date"
                                                 xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                                    <xsd:element name="lastTrainOfDay" type="xsd:date"
                                                 xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                                </xsd:choice>
                            </xsd:complexType>
                        </xsd:element>
                        <xsd:choice xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                            <xsd:annotation xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                                <xsd:documentation xmlns:xsd="http://www.w3.org/2001/XMLSchema">Request may include a
                                    choice of via, interchange or excluded interchange details
                                </xsd:documentation>
                            </xsd:annotation>
                            <xsd:sequence xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                                <xsd:element maxOccurs="unbounded" minOccurs="0" name="via" type="ns0:CrsCode"
                                             xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                                <xsd:element maxOccurs="unbounded" minOccurs="0" name="notVia" type="ns0:CrsCode"
                                             xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                            </xsd:sequence>
                            <xsd:sequence xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                                <xsd:element maxOccurs="unbounded" name="interchange" type="ns0:CrsCode"
                                             xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                            </xsd:sequence>
                            <xsd:sequence xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                                <xsd:element maxOccurs="unbounded" name="excludedInterchanges" type="ns0:CrsCode"
                                             xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                            </xsd:sequence>
                        </xsd:choice>
                        <xsd:element name="directTrains" type="xsd:boolean"
                                     xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                        <xsd:element minOccurs="0" name="fareRequestDetails"
                                     xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                            <xsd:annotation xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                                <xsd:documentation xmlns:xsd="http://www.w3.org/2001/XMLSchema">Populate the fare
                                    request details element to retrieve fare data.
                                </xsd:documentation>
                            </xsd:annotation>
                            <xsd:complexType xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                                <xsd:sequence xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                                    <xsd:element name="passengers" type="ns0:PassengerCounts"
                                                 xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                                    <xsd:element name="fareClass" type="ns0:FareClassEnum"
                                                 xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                                    <xsd:sequence xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                                        <xsd:element maxOccurs="unbounded" minOccurs="0" name="railcard"
                                                     xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                                            <xsd:complexType xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                                                <xsd:sequence xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                                                    <xsd:element name="code" type="ns0:RailCardCode"
                                                                 xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                                                    <xsd:element name="count" type="xsd:int"
                                                                 xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                                                </xsd:sequence>
                                            </xsd:complexType>
                                        </xsd:element>
                                    </xsd:sequence>
                                </xsd:sequence>
                            </xsd:complexType>
                        </xsd:element>
                        <xsd:element minOccurs="0" name="reducedTransferTime" type="xsd:boolean"
                                     xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                        <xsd:element minOccurs="0" name="onlySearchForSleeper" type="xsd:boolean"
                                     xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                        <xsd:element minOccurs="0" name="overtakenTrains" type="xsd:boolean"
                                     xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                        <xsd:element minOccurs="0" name="increasedInterchange" type="ns0:IncreaseInterchangeTime"
                                     xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                        <xsd:element minOccurs="0" name="operator" type="ns0:Operator"
                                     xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                        <xsd:element minOccurs="0" name="rawRealtimeInfo" type="xsd:boolean"
                                     xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                        <xsd:element minOccurs="0" name="planAnytimeToday" type="xsd:boolean"
                                     xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    </xsd:sequence>
                </xsd:complexType>
            </xsd:element>
            <xsd:element name="RealtimeJourneyPlanResponse" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                <xsd:annotation xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                    <xsd:documentation xmlns:xsd="http://www.w3.org/2001/XMLSchema">Realtime journey planning response
                    </xsd:documentation>
                </xsd:annotation>
                <xsd:complexType xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                    <xsd:complexContent xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                        <xsd:extension base="ns0:ReturnResponseType" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                            <xsd:sequence xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                                <xsd:element name="generatedTime" type="xsd:dateTime"
                                             xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                                <xsd:element maxOccurs="5" minOccurs="0" name="outwardJourney" type="Journey"
                                             xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                                    <xsd:annotation xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                                        <xsd:appinfo xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                                            <jaxb:property xmlns:jaxb="http://java.sun.com/xml/ns/jaxb"
                                                           name="outwardJourneys"/>
                                        </xsd:appinfo>
                                    </xsd:annotation>
                                </xsd:element>
                                <xsd:element maxOccurs="5" minOccurs="0" name="inwardJourney" type="Journey"
                                             xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                                    <xsd:annotation xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                                        <xsd:appinfo xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                                            <jaxb:property xmlns:jaxb="http://java.sun.com/xml/ns/jaxb"
                                                           name="inwardJourneys"/>
                                        </xsd:appinfo>
                                    </xsd:annotation>
                                </xsd:element>
                                <xsd:element minOccurs="0" name="rarsStatus" type="RarsStatus"
                                             xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                            </xsd:sequence>
                        </xsd:extension>
                    </xsd:complexContent>
                </xsd:complexType>
            </xsd:element>
            <xsd:element name="RealtimeCallingPointsRequest" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                <xsd:annotation xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                    <xsd:documentation xmlns:xsd="http://www.w3.org/2001/XMLSchema">Realtime calling points request
                    </xsd:documentation>
                </xsd:annotation>
                <xsd:complexType xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                    <xsd:sequence xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                        <xsd:element name="origin" type="ns0:StationCrs" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                        <xsd:element name="destination" type="ns0:StationCrs"
                                     xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                        <xsd:element name="departure" type="xsd:dateTime" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                        <xsd:element name="arrival" type="xsd:dateTime" xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                    </xsd:sequence>
                </xsd:complexType>
            </xsd:element>
            <xsd:element name="RealtimeCallingPointsResponse" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                <xsd:annotation xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                    <xsd:documentation xmlns:xsd="http://www.w3.org/2001/XMLSchema">Realtime calling points response
                    </xsd:documentation>
                </xsd:annotation>
                <xsd:complexType xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                    <xsd:complexContent xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                        <xsd:extension base="ns0:ReturnResponseType" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                            <xsd:sequence xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                                <xsd:element name="origin" type="ns0:StationCrs"
                                             xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                                <xsd:element name="destination" type="ns0:StationCrs"
                                             xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                                <xsd:element name="generatedTime" type="xsd:dateTime"
                                             xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                                <xsd:element maxOccurs="unbounded" name="leg"
                                             xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                                    <xsd:complexType xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                                        <xsd:sequence xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                                            <xsd:element name="id" type="ns0:Id"
                                                         xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                                            <xsd:element name="origin" type="ns0:StationCrs"
                                                         xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                                            <xsd:element name="destination" type="ns0:StationCrs"
                                                         xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                                            <xsd:element name="departure" type="xsd:dateTime"
                                                         xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                                            <xsd:element name="arrival" type="xsd:dateTime"
                                                         xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                                            <xsd:sequence xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                                                <xsd:element name="searchStatus" type="ns0:CallingPointsSearchStatus"
                                                             xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                                                <xsd:element maxOccurs="unbounded" name="realtimeCallingPoint"
                                                             xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                                                    <xsd:complexType xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                                                        <xsd:sequence xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                                                            <xsd:element name="station" type="ns0:StationCrs"
                                                                         xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                                                            <xsd:element minOccurs="0" name="board" type="xsd:boolean"
                                                                         xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                                                            <xsd:element minOccurs="0" name="alight" type="xsd:boolean"
                                                                         xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                                                            <xsd:element minOccurs="0" name="platform"
                                                                         type="ns0:Platform"
                                                                         xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                                                            <xsd:element name="timetable"
                                                                         xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                                                                <xsd:complexType
                                                                        xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                                                                    <xsd:sequence
                                                                            xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                                                                        <xsd:element name="scheduledTimes"
                                                                                     xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                                                                            <xsd:complexType
                                                                                    xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                                                                                <xsd:sequence
                                                                                        xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                                                                                    <xsd:element minOccurs="0"
                                                                                                 name="arrival"
                                                                                                 type="xsd:dateTime"
                                                                                                 xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                                                                                    <xsd:element minOccurs="0"
                                                                                                 name="departure"
                                                                                                 type="xsd:dateTime"
                                                                                                 xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                                                                                </xsd:sequence>
                                                                            </xsd:complexType>
                                                                        </xsd:element>
                                                                    </xsd:sequence>
                                                                </xsd:complexType>
                                                            </xsd:element>
                                                            <xsd:element name="realtime"
                                                                         xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                                                                <xsd:complexType
                                                                        xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                                                                    <xsd:sequence
                                                                            xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                                                                        <xsd:element minOccurs="0" name="updatedTimes"
                                                                                     xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                                                                            <xsd:complexType
                                                                                    xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                                                                                <xsd:sequence
                                                                                        xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                                                                                    <xsd:element minOccurs="0"
                                                                                                 name="arrival"
                                                                                                 xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                                                                                        <xsd:complexType
                                                                                                xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                                                                                            <xsd:sequence
                                                                                                    xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                                                                                                <xsd:element name="time"
                                                                                                             type="xsd:dateTime"
                                                                                                             xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                                                                                                <xsd:element
                                                                                                        minOccurs="0"
                                                                                                        name="type"
                                                                                                        type="ns0:UpdatedTimeType"
                                                                                                        xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                                                                                                <xsd:element
                                                                                                        name="overdue"
                                                                                                        type="xsd:boolean"
                                                                                                        xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                                                                                                <xsd:element
                                                                                                        name="delayed"
                                                                                                        type="xsd:boolean"
                                                                                                        xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                                                                                            </xsd:sequence>
                                                                                        </xsd:complexType>
                                                                                    </xsd:element>
                                                                                    <xsd:element minOccurs="0"
                                                                                                 name="departure"
                                                                                                 xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                                                                                        <xsd:complexType
                                                                                                xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                                                                                            <xsd:sequence
                                                                                                    xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                                                                                                <xsd:element name="time"
                                                                                                             type="xsd:dateTime"
                                                                                                             xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                                                                                                <xsd:element
                                                                                                        minOccurs="0"
                                                                                                        name="type"
                                                                                                        type="ns0:UpdatedTimeType"
                                                                                                        xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                                                                                                <xsd:element
                                                                                                        name="overdue"
                                                                                                        type="xsd:boolean"
                                                                                                        xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                                                                                                <xsd:element
                                                                                                        name="delayed"
                                                                                                        type="xsd:boolean"
                                                                                                        xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                                                                                            </xsd:sequence>
                                                                                        </xsd:complexType>
                                                                                    </xsd:element>
                                                                                </xsd:sequence>
                                                                            </xsd:complexType>
                                                                        </xsd:element>
                                                                        <xsd:element name="cancelled" type="xsd:boolean"
                                                                                     xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                                                                        <xsd:element minOccurs="0"
                                                                                     name="cancellationReason"
                                                                                     type="xsd:string"
                                                                                     xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                                                                        <xsd:element minOccurs="0"
                                                                                     name="lateRunningReason"
                                                                                     type="xsd:string"
                                                                                     xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                                                                    </xsd:sequence>
                                                                </xsd:complexType>
                                                            </xsd:element>
                                                        </xsd:sequence>
                                                    </xsd:complexType>
                                                </xsd:element>
                                            </xsd:sequence>
                                            <xsd:element minOccurs="0" name="associations"
                                                         xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                                                <xsd:complexType xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                                                    <xsd:sequence xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                                                        <xsd:element maxOccurs="unbounded" name="associationStation"
                                                                     xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                                                            <xsd:complexType
                                                                    xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                                                                <xsd:sequence
                                                                        xmlns:xsd="http://www.w3.org/2001/XMLSchema">
                                                                    <xsd:element name="station" type="ns0:StationCrs"
                                                                                 xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                                                                    <xsd:element name="type" type="ns0:AssociationType"
                                                                                 xmlns:xsd="http://www.w3.org/2001/XMLSchema"/>
                                                                </xsd:sequence>
                                                            </xsd:complexType>
                                                        </xsd:element>
                                                    </xsd:sequence>
                                                </xsd:complexType>
                                            </xsd:element>
